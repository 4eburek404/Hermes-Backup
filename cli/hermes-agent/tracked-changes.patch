+def protected_context_file_for_path(path: str | os.PathLike | None) -> Optional[str]:
+    """Return protected Hermes context-file label for *path*, else None.
+
+    Covers profile-scoped built-in memory files and SOUL.md. Comparison uses
+    resolved absolute paths so aliases like ``~`` and relative paths cannot
+    bypass file-tool checks.
+    """
+    if not path:
+        return None
+    try:
+        from hermes_constants import get_hermes_home
+        hermes_home = get_hermes_home().expanduser().resolve()
+        candidate = Path(path).expanduser()
+        if not candidate.is_absolute():
+            candidate = (Path.cwd() / candidate)
+        candidate = candidate.resolve()
+    except Exception:
+        return None
+
+    protected = {
+        hermes_home / "memories" / "MEMORY.md": "MEMORY.md",
+        hermes_home / "memories" / "USER.md": "USER.md",
+        hermes_home / "SOUL.md": "SOUL.md",
+    }
+    return protected.get(candidate)
+
+
+def check_protected_context_file_write(
+    path: str | os.PathLike | None,
+    operation: str = "write",
+    approval_callback=None,

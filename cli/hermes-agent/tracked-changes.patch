+    is_gateway = os.getenv("HERMES_GATEWAY_SESSION")
+    is_ask = os.getenv("HERMES_EXEC_ASK")
+    is_cron = os.getenv("HERMES_CRON_SESSION")
+    if not (is_cli or is_gateway or is_ask or is_cron):
+        return {"approved": True, "message": None}

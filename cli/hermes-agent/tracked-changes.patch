+def _systemd_timespec_to_seconds(raw: str) -> float:
+    """Parse a systemd timespec value into seconds."""
+    text = (raw or "").strip().lower()
+    if not text or text == "infinity":
+        return 0.0
+
+    total = 0.0
+    matched = False
+    for part in text.split():
+        for suffix, multiplier in (
+            ("ms", 0.001),
+            ("us", 0.000001),
+            ("sec", 1.0),
+            ("s", 1.0),
+            ("min", 60.0),
+            ("h", 3600.0),
+            ("d", 86400.0),
+        ):
+            if part.endswith(suffix):
+                try:
+                    value = float(part[: -len(suffix)])
+                except ValueError:
+                    break
+                total += value * multiplier
+                matched = True
+                break
+    return total if matched else 0.0
+
+
+def _systemd_restart_wait_timeout(system: bool = False) -> float:
+    """Return a practical timeout while waiting for a systemd service restart."""
+    props = _read_systemd_unit_properties(system=system, properties=("RestartUSec",))
+    restart_wait_sec = _systemd_timespec_to_seconds(props.get("RestartUSec", ""))
+    # Keep the classic 60-second floor, then add a short grace period on top
+    # of RestartSec so callers tolerate the restart cooldown + tiny startup jitter.
+    return max(60.0, restart_wait_sec + 10.0)
+

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/schemas/skill-audit/audit-report.schema.json",
  "title": "Hermes Skill Audit Report",
  "type": "object",
  "required": [
    "schema_version",
    "tool",
    "repo",
    "target",
    "summary",
    "findings",
    "checks",
    "evidence_manifest"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "audit_skill"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "repo": {
      "type": "object",
      "required": [
        "root",
        "dirty",
        "changed_files",
        "staged_files",
        "untracked_files"
      ],
      "properties": {
        "root": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirty": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "staged_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "untracked_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "target": {
      "type": "object",
      "required": [
        "mode",
        "skill",
        "path"
      ],
      "properties": {
        "mode": {
          "enum": [
            "single",
            "changed",
            "all",
            "error"
          ]
        },
        "skill": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "input": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "blockers",
        "warnings",
        "recommendations",
        "info"
      ],
      "properties": {
        "blockers": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        },
        "recommendations": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "severity",
          "category",
          "message",
          "location",
          "evidence",
          "fingerprint"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "blocker",
              "warning",
              "recommendation",
              "info"
            ]
          },
          "category": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "location": {
            "type": "object"
          },
          "evidence": {
            "type": "object"
          },
          "suggested_fix": {
            "type": [
              "string",
              "null"
            ]
          },
          "fingerprint": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "status"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "evidence_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "kind",
          "exists"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/schemas/flight-calendar-ics-cli.v1.json",
  "title": "flight-calendar-ics CLI envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "command",
    "process"
  ],
  "properties": {
    "schema_version": {
      "const": "flight-calendar-ics-cli.v1"
    },
    "ok": {
      "type": "boolean"
    },
    "command": {
      "type": "string",
      "enum": [
        "doctor",
        "validate",
        "make",
        "aeroflot",
        "ural",
        "utair"
      ]
    },
    "process": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "step": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error",
              "skipped"
            ]
          },
          "reason": {
            "type": "string"
          },
          "segments_count": {
            "type": "integer",
            "minimum": 0
          },
          "artifact": {
            "type": "string",
            "enum": [
              "json",
              "ics"
            ]
          },
          "mode": {
            "type": "string",
            "pattern": "^[0-7]{3,4}$"
          },
          "overrides_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "type": "string"
        },
        "entrypoint_kind": {
          "const": "single-python-executable"
        },
        "schema_version": {
          "const": "flight-calendar-ics-cli.v1"
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "doctor",
              "validate",
              "make",
              "aeroflot",
              "ural",
              "utair"
            ]
          }
        },
        "legacy_scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "json_contract": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ok": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "process": {
              "type": "string"
            },
            "data": {
              "type": "string"
            },
            "error": {
              "type": "string"
            }
          }
        },
        "sensitive_stdout_policy": {
          "type": "string"
        },
        "segments_count": {
          "type": "integer",
          "minimum": 0
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "flight_number": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "route": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "dtstart_utc": {
                "type": "string"
              },
              "dtend_utc": {
                "type": "string"
              },
              "departure_local": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "arrival_local": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "write_performed": {
          "type": "boolean"
        },
        "ics_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "json_path": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
